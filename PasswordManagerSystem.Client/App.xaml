<Application x:Class="PasswordManagerSystem.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PasswordManagerSystem.Client.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme -->
                <ResourceDictionary Source="Resources/Themes/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Typography.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Icons.xaml"/>

                <!-- Styles -->
                <ResourceDictionary Source="Resources/Styles/Window.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Buttons.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Inputs.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Lists.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Globális converterek (kulcs nélkül x:Key-ek alapján bindolva) -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Inverse="True"/>
            <conv:InverseBoolConverter x:Key="InvBool"/>
            <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis"/>
            <conv:NotNullToVisibilityConverter x:Key="NotNullToVis"/>
            <conv:ConnectionTypeConverter x:Key="ConnTypeConv"/>
            <conv:ShortDateTimeConverter x:Key="ShortDateConv"/>
            <conv:InitialsConverter x:Key="InitialsConv"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
