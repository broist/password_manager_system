        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Size.MD}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Accent.Default}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource Brush.Accent.Default}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
