<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Modern, profi sötét téma a Password Manager System klienshez.
        Inspiráció: Linear, Vercel, Bitwarden, JetBrains 2024 design.
        A színpaletta tudatosan visszafogott, de van egy markáns accent
        (Cyan-300) ami a brandet és a CTA-kat hordozza.
    -->

    <!-- Surfaces (háttér rétegek) -->
    <Color x:Key="Color.Surface.Base">#0B0E14</Color>           <!-- legmélyebb háttér -->
    <Color x:Key="Color.Surface.Sidebar">#0F131A</Color>         <!-- sidebar -->
    <Color x:Key="Color.Surface.Panel">#141923</Color>           <!-- main content panelek -->
    <Color x:Key="Color.Surface.Elevated">#1A2030</Color>        <!-- kártyák, gombok -->
    <Color x:Key="Color.Surface.Overlay">#202739</Color>         <!-- hover, kiválasztott sor -->
    <Color x:Key="Color.Surface.Tooltip">#2A3245</Color>

    <!-- Borders -->
    <Color x:Key="Color.Border.Subtle">#1F2533</Color>
    <Color x:Key="Color.Border.Default">#2A3245</Color>
    <Color x:Key="Color.Border.Strong">#3A4256</Color>
    <Color x:Key="Color.Border.Focus">#22D3EE</Color>            <!-- megegyezik az accent-tel -->

    <!-- Text -->
    <Color x:Key="Color.Text.Primary">#E5E7EB</Color>
    <Color x:Key="Color.Text.Secondary">#9CA3AF</Color>
    <Color x:Key="Color.Text.Tertiary">#6B7280</Color>
    <Color x:Key="Color.Text.Disabled">#4B5563</Color>
    <Color x:Key="Color.Text.OnAccent">#031316</Color>            <!-- gomb felirat az accent-en -->
    <Color x:Key="Color.Text.Inverse">#0B0E14</Color>

    <!-- Accent (brand) — Cyan, mert ez a "biztonság / digitális" érzet,
         de visszafogottabb mint a klasszikus kék — egyedibb hatás. -->
    <Color x:Key="Color.Accent.Default">#22D3EE</Color>
    <Color x:Key="Color.Accent.Hover">#67E8F9</Color>
    <Color x:Key="Color.Accent.Pressed">#06B6D4</Color>
    <Color x:Key="Color.Accent.Subtle">#0E3F47</Color>            <!-- accent háttérhez (kis opacity) -->
    <Color x:Key="Color.Accent.SubtleHover">#114650</Color>

    <!-- Semantic colors -->
    <Color x:Key="Color.Success">#10B981</Color>
    <Color x:Key="Color.Success.Subtle">#062E22</Color>
    <Color x:Key="Color.Warning">#F59E0B</Color>
    <Color x:Key="Color.Warning.Subtle">#3A2706</Color>
    <Color x:Key="Color.Danger">#EF4444</Color>
    <Color x:Key="Color.Danger.Subtle">#3A0F12</Color>
    <Color x:Key="Color.Info">#3B82F6</Color>
    <Color x:Key="Color.Info.Subtle">#0F2342</Color>

    <!-- Role badges (jellemző színek minden szerepkörnek) -->
    <Color x:Key="Color.Role.ItAdmin">#A855F7</Color>             <!-- purple -->
    <Color x:Key="Color.Role.It">#22D3EE</Color>                  <!-- cyan -->
    <Color x:Key="Color.Role.Consultant">#10B981</Color>          <!-- green -->
    <Color x:Key="Color.Role.Support">#F59E0B</Color>             <!-- amber -->

    <!-- Shadow color (very subtle) -->
    <Color x:Key="Color.Shadow">#000000</Color>

    <!-- =============================================================
         Brushes (a fenti színekből, hogy a styles könnyen használja őket)
         ============================================================= -->

    <SolidColorBrush x:Key="Brush.Surface.Base" Color="{StaticResource Color.Surface.Base}"/>
    <SolidColorBrush x:Key="Brush.Surface.Sidebar" Color="{StaticResource Color.Surface.Sidebar}"/>
    <SolidColorBrush x:Key="Brush.Surface.Panel" Color="{StaticResource Color.Surface.Panel}"/>
    <SolidColorBrush x:Key="Brush.Surface.Elevated" Color="{StaticResource Color.Surface.Elevated}"/>
    <SolidColorBrush x:Key="Brush.Surface.Overlay" Color="{StaticResource Color.Surface.Overlay}"/>
    <SolidColorBrush x:Key="Brush.Surface.Tooltip" Color="{StaticResource Color.Surface.Tooltip}"/>

    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Color.Border.Subtle}"/>
    <SolidColorBrush x:Key="Brush.Border.Default" Color="{StaticResource Color.Border.Default}"/>
    <SolidColorBrush x:Key="Brush.Border.Strong" Color="{StaticResource Color.Border.Strong}"/>
    <SolidColorBrush x:Key="Brush.Border.Focus" Color="{StaticResource Color.Border.Focus}"/>

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}"/>
    <SolidColorBrush x:Key="Brush.Text.Tertiary" Color="{StaticResource Color.Text.Tertiary}"/>
    <SolidColorBrush x:Key="Brush.Text.Disabled" Color="{StaticResource Color.Text.Disabled}"/>
    <SolidColorBrush x:Key="Brush.Text.OnAccent" Color="{StaticResource Color.Text.OnAccent}"/>
    <SolidColorBrush x:Key="Brush.Text.Inverse" Color="{StaticResource Color.Text.Inverse}"/>

    <SolidColorBrush x:Key="Brush.Accent.Default" Color="{StaticResource Color.Accent.Default}"/>
    <SolidColorBrush x:Key="Brush.Accent.Hover" Color="{StaticResource Color.Accent.Hover}"/>
    <SolidColorBrush x:Key="Brush.Accent.Pressed" Color="{StaticResource Color.Accent.Pressed}"/>
    <SolidColorBrush x:Key="Brush.Accent.Subtle" Color="{StaticResource Color.Accent.Subtle}"/>
    <SolidColorBrush x:Key="Brush.Accent.SubtleHover" Color="{StaticResource Color.Accent.SubtleHover}"/>

    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="Brush.Success.Subtle" Color="{StaticResource Color.Success.Subtle}"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush x:Key="Brush.Warning.Subtle" Color="{StaticResource Color.Warning.Subtle}"/>
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}"/>
    <SolidColorBrush x:Key="Brush.Danger.Subtle" Color="{StaticResource Color.Danger.Subtle}"/>
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}"/>
    <SolidColorBrush x:Key="Brush.Info.Subtle" Color="{StaticResource Color.Info.Subtle}"/>

    <SolidColorBrush x:Key="Brush.Role.ItAdmin" Color="{StaticResource Color.Role.ItAdmin}"/>
    <SolidColorBrush x:Key="Brush.Role.It" Color="{StaticResource Color.Role.It}"/>
    <SolidColorBrush x:Key="Brush.Role.Consultant" Color="{StaticResource Color.Role.Consultant}"/>
    <SolidColorBrush x:Key="Brush.Role.Support" Color="{StaticResource Color.Role.Support}"/>

    <!-- Egy nagyon halvány gradient a login háttérhez (az accent-ből) -->
    <LinearGradientBrush x:Key="Brush.Login.Background" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0B0E14" Offset="0"/>
        <GradientStop Color="#0F1A22" Offset="0.5"/>
        <GradientStop Color="#0B0E14" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
