<UserControl x:Class="PasswordManagerSystem.Client.Views.Access.AccessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="AccessDarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F2937"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#263244"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccessDarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource AccessDarkComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#111827"
                                                BorderBrush="#374151"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>

                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="8,0,4,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  RecognizesAccessKey="True"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>

                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#CBD5E1"
                                                      Width="8"
                                                      Height="5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#111827"
                                        BorderBrush="#374151"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer Margin="0"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6B7280"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#4B5563"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Brush.Surface.Panel}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Companies -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="24,22,20,16">
                <StackPanel>
                    <TextBlock Text="Hozzáférések"
                               Style="{StaticResource Text.Heading2}"/>
                    <TextBlock Style="{StaticResource Text.Caption}"
                               Margin="0,5,0,0">
                        <Run Text="{Binding Companies.Count, Mode=OneWay}"/>
                        <Run Text=" db aktív cég"/>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <ListBox Grid.Row="1"
                     Margin="14,0,14,16"
                     ItemsSource="{Binding Companies}"
                     SelectedItem="{Binding SelectedCompany, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="34"
                                    Height="34"
                                    CornerRadius="8"
                                    Background="{DynamicResource Brush.Surface.Elevated}"
                                    VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.Building}"
                                      Stroke="{DynamicResource Brush.Text.Secondary}"
                                      StrokeThickness="1.5"
                                      Width="17"
                                      Height="17"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource Text.Body}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Border Grid.Column="1"
                Background="{DynamicResource Brush.Border.Subtle}"/>

        <!-- Company credential access overview -->
        <Grid Grid.Column="2">
            <StackPanel Visibility="{Binding HasSelectedCompany, Converter={StaticResource InvBoolToVis}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="380">
                <TextBlock Text="Nincs kiválasztott cég"
                           Style="{StaticResource Text.Heading3}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Válassz ki egy céget a bal oldali listából."
                           Style="{StaticResource Text.Body}"
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <Grid Visibility="{Binding HasSelectedCompany, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Padding="30,24"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding SelectedCompany.Name}"
                                       Style="{StaticResource Text.Heading2}"
                                       TextTrimming="CharacterEllipsis"/>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,8,0,0">
                                <Path Data="{StaticResource Icon.Shield}"
                                      Stroke="{DynamicResource Brush.Text.Tertiary}"
                                      StrokeThickness="1.5"
                                      Width="14"
                                      Height="14"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"/>
                                <TextBlock Style="{StaticResource Text.BodySmall}"
                                           Margin="7,0,0,0"
                                           VerticalAlignment="Center">
                                    <Run Text="{Binding Credentials.Count, Mode=OneWay}"/>
                                    <Run Text=" db bejegyzés hozzáférési összefoglalója"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Frissítés"
                                Style="{StaticResource Button.Secondary}"
                                Padding="14,7"
                                VerticalAlignment="Top"
                                Command="{Binding RefreshAccessViewCommand}"
                                ToolTip="Aktuális hozzáférési nézet frissítése"/>
                    </Grid>
                </Border>

                <!-- Access table -->
                <Grid Grid.Row="1"
                      Margin="30,24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="BEJEGYZÉSEK HOZZÁFÉRÉSI TÁBLÁZATA"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,0,0,10"/>

                    <Border Grid.Row="1"
                            CornerRadius="12"
                            Background="{DynamicResource Brush.Surface.Elevated}"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            ClipToBounds="True">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Table header -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource Brush.Surface.Base}"
                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="0,0,0,1">
                                <Grid Margin="16,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*"/>
                                        <ColumnDefinition Width="1.65*"/>
                                        <ColumnDefinition Width="1.55*"/>
                                        <ColumnDefinition Width="2.0*"/>
                                        <ColumnDefinition Width="2.2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="TÍPUS"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource Brush.Text.Secondary}"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Padding="0"
                                            Command="{Binding SortByTypeCommand}"
                                            ToolTip="Rendezés típus szerint"/>

                                    <TextBlock Grid.Column="1"
                                               Text="BEJEGYZÉS"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                               Text="KAPCSOLÓDÁS"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="3"
                                               Text="SZEREPKÖR"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="4"
                                               Text="ALKALMI HOZZÁFÉRÉSEK"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="5"
                                               Text="MŰVELET"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Table body -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">

                                <ItemsControl ItemsSource="{Binding CredentialItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                    BorderThickness="0,0,0,1"
                                                    Background="{DynamicResource Brush.Surface.Elevated}"
                                                    Padding="0">
                                                <Grid Margin="16,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.05*"/>
                                                        <ColumnDefinition Width="1.65*"/>
                                                        <ColumnDefinition Width="1.55*"/>
                                                        <ColumnDefinition Width="2.0*"/>
                                                        <ColumnDefinition Width="2.2*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Type -->
                                                    <Grid Grid.Column="0"
                                                          Margin="0,0,16,0"
                                                          VerticalAlignment="Top">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Width="38"
                                                                Height="38"
                                                                CornerRadius="10"
                                                                VerticalAlignment="Top"
                                                                Margin="0,0,10,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#374151"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Credential.CredentialType}" Value="GENERIC">
                                                                            <Setter Property="Background" Value="#374151"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Credential.CredentialType}" Value="DATABASE">
                                                                            <Setter Property="Background" Value="#312E81"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Credential.CredentialType}" Value="WINDOWS_SERVER">
                                                                            <Setter Property="Background" Value="#1E3A8A"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Credential.CredentialType}" Value="LINUX_SERVER">
                                                                            <Setter Property="Background" Value="#064E3B"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>

                                                            <Path Width="18"
                                                                  Height="18"
                                                                  Stretch="Uniform"
                                                                  Stroke="#F9FAFB"
                                                                  StrokeThickness="1.7"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center">
                                                                <Path.Style>
                                                                    <Style TargetType="Path">
                                                                        <Setter Property="Data" Value="{StaticResource Icon.Key}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Credential.CredentialType}" Value="GENERIC">
                                                                                <Setter Property="Data" Value="{StaticResource Icon.Key}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Credential.CredentialType}" Value="DATABASE">
                                                                                <Setter Property="Data" Value="{StaticResource Icon.Database}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Credential.CredentialType}" Value="WINDOWS_SERVER">
                                                                                <Setter Property="Data" Value="{StaticResource Icon.Monitor}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Credential.CredentialType}" Value="LINUX_SERVER">
                                                                                <Setter Property="Data" Value="{StaticResource Icon.Terminal}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Path.Style>
                                                            </Path>
                                                        </Border>

                                                        <StackPanel Grid.Column="1"
                                                                    VerticalAlignment="Top">
                                                            <Border CornerRadius="5"
                                                                    Padding="6,2"
                                                                    HorizontalAlignment="Left">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#374151"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Credential.CredentialType}" Value="GENERIC">
                                                                                <Setter Property="Background" Value="#374151"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Credential.CredentialType}" Value="DATABASE">
                                                                                <Setter Property="Background" Value="#312E81"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Credential.CredentialType}" Value="WINDOWS_SERVER">
                                                                                <Setter Property="Background" Value="#1E3A8A"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Credential.CredentialType}" Value="LINUX_SERVER">
                                                                                <Setter Property="Background" Value="#064E3B"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>

                                                                <TextBlock Text="{Binding Credential.CredentialType, Converter={StaticResource CredentialTypeShortNameConv}}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#F9FAFB"/>
                                                            </Border>

                                                            <TextBlock Text="{Binding Credential.CredentialType, Converter={StaticResource CredentialTypeDisplayNameConv}}"
                                                                       Style="{StaticResource Text.Caption}"
                                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                                       Margin="0,4,0,0"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- Credential -->
                                                    <StackPanel Grid.Column="1"
                                                                Margin="0,0,16,0"
                                                                VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding Title}"
                                                                   Style="{StaticResource Text.BodySmall}"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <TextBlock Text="{Binding CompanyName}"
                                                                   Style="{StaticResource Text.Caption}"
                                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                                   Margin="0,3,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <!-- Connection -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding ConnectionValue, TargetNullValue=Nincs kapcsolódás}"
                                                               Style="{StaticResource Text.Caption}"
                                                               Foreground="{DynamicResource Brush.Text.Secondary}"
                                                               Margin="0,2,16,0"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Top"/>

                                                    <!-- Role access -->
                                                    <StackPanel Grid.Column="3"
                                                                Margin="0,0,16,0"
                                                                VerticalAlignment="Top">
                                                        <Grid Visibility="{Binding DataContext.CanManageRoleAccess, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <ComboBox Grid.Column="0"
                                                                      ItemsSource="{Binding RoleAccessOptions}"
                                                                      SelectedItem="{Binding SelectedRoleAccessOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      Style="{StaticResource AccessDarkComboBoxStyle}"
                                                                      MinWidth="150"
                                                                      Height="32"
                                                                      Margin="0,0,8,0"
                                                                      ToolTip="Minimum szerepkör kiválasztása">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   Foreground="#F9FAFB"/>
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>

                                                            <Button Grid.Column="1"
                                                                    Content="Mentés"
                                                                    Style="{StaticResource Button.Secondary}"
                                                                    Padding="12,6"
                                                                    Command="{Binding DataContext.SetRoleAccessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="Szerepkör-alapú hozzáférés mentése"/>
                                                        </Grid>
                                                    </StackPanel>

                                                    <!-- Temporary access -->
                                                    <StackPanel Grid.Column="4"
                                                                Margin="0,0,16,0"
                                                                VerticalAlignment="Top">

                                                        <TextBlock Text="Nincs aktív alkalmi hozzáférés"
                                                                   Style="{StaticResource Text.Caption}"
                                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                                   Visibility="{Binding HasTemporaryAccessRules, Converter={StaticResource InvBoolToVis}}"/>

                                                        <ItemsControl ItemsSource="{Binding TemporaryAccessRules}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border CornerRadius="6"
                                                                            Background="{DynamicResource Brush.Surface.Base}"
                                                                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                                            BorderThickness="1"
                                                                            Padding="8,6"
                                                                            Margin="0,0,0,6">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>

                                                                            <StackPanel Grid.Column="0"
                                                                                        Margin="0,0,8,0">
                                                                                <TextBlock Text="{Binding AdUsername, TargetNullValue=Ismeretlen felhasználó}"
                                                                                           Style="{StaticResource Text.BodySmall}"
                                                                                           FontWeight="SemiBold"
                                                                                           TextTrimming="CharacterEllipsis"/>

                                                                                <TextBlock Text="{Binding ExpiresAt, Converter={StaticResource ShortDateConv}, StringFormat=Lejár: {0}}"
                                                                                           Style="{StaticResource Text.Caption}"
                                                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                                                           Margin="0,2,0,0"/>
                                                                            </StackPanel>

                                                                            <Button Grid.Column="1"
                                                                                    Content="Vissza"
                                                                                    Command="{Binding DataContext.RevokeAccessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                    CommandParameter="{Binding}"
                                                                                    VerticalAlignment="Center"
                                                                                    Padding="8,4"
                                                                                    ToolTip="Alkalmi hozzáférés visszavonása"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>

                                                    <!-- Actions -->
                                                    <StackPanel Grid.Column="5"
                                                                Orientation="Vertical"
                                                                VerticalAlignment="Top"
                                                                HorizontalAlignment="Right">
                                                        <Button Content="Alkalmi hozzáférés"
                                                                Style="{StaticResource Button.Secondary}"
                                                                Padding="12,7"
                                                                Visibility="{Binding DataContext.CanManageUserAccess, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                                                Command="{Binding DataContext.GrantTemporaryAccessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="Felhasználó-alapú időkorlátos hozzáférés adása"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="2"
                               Text="Megjegyzés: az alkalmi hozzáférések létrehozása és visszavonása működik. A szerepkör-alapú hozzáférés szerkesztése csak ITAdmin szerepkörrel érhető el."
                               Style="{StaticResource Text.Caption}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>