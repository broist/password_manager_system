<UserControl x:Class="PasswordManagerSystem.Client.Views.Access.AccessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{DynamicResource Brush.Surface.Panel}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Companies -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="24,22,20,16">
                <StackPanel>
                    <TextBlock Text="Hozzáférések"
                               Style="{StaticResource Text.Heading2}"/>
                    <TextBlock Style="{StaticResource Text.Caption}"
                               Margin="0,5,0,0">
                        <Run Text="{Binding Companies.Count, Mode=OneWay}"/>
                        <Run Text=" db aktív cég"/>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <ListBox Grid.Row="1"
                     Margin="14,0,14,16"
                     ItemsSource="{Binding Companies}"
                     SelectedItem="{Binding SelectedCompany, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="34"
                                    Height="34"
                                    CornerRadius="8"
                                    Background="{DynamicResource Brush.Surface.Elevated}"
                                    VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.Building}"
                                      Stroke="{DynamicResource Brush.Text.Secondary}"
                                      StrokeThickness="1.5"
                                      Width="17"
                                      Height="17"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource Text.Body}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Border Grid.Column="1"
                Background="{DynamicResource Brush.Border.Subtle}"/>

        <!-- Company credential access overview -->
        <Grid Grid.Column="2">
            <StackPanel Visibility="{Binding HasSelectedCompany, Converter={StaticResource InvBoolToVis}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="380">
                <TextBlock Text="Nincs kiválasztott cég"
                           Style="{StaticResource Text.Heading3}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Válassz ki egy céget a bal oldali listából."
                           Style="{StaticResource Text.Body}"
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <Grid Visibility="{Binding HasSelectedCompany, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Padding="30,24"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedCompany.Name}"
                                   Style="{StaticResource Text.Heading2}"
                                   TextTrimming="CharacterEllipsis"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,8,0,0">
                            <Path Data="{StaticResource Icon.Shield}"
                                  Stroke="{DynamicResource Brush.Text.Tertiary}"
                                  StrokeThickness="1.5"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource Text.BodySmall}"
                                       Margin="7,0,0,0"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding Credentials.Count, Mode=OneWay}"/>
                                <Run Text=" db bejegyzés hozzáférési összefoglalója"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Credential cards -->
                <ScrollViewer Grid.Row="1"
                              Padding="30,24"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel>
                        <TextBlock Text="BEJEGYZÉSEK"
                                   Style="{StaticResource Text.Caption}"
                                   Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding CredentialItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Background="{DynamicResource Brush.Surface.Elevated}"
                                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                            BorderThickness="1"
                                            Padding="16,14"
                                            Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Credential header -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{StaticResource Text.Body}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <TextBlock Text="{Binding ConnectionValue, TargetNullValue=Nincs kapcsolódás}"
                                                               Style="{StaticResource Text.Caption}"
                                                               Margin="0,3,0,0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <Button Grid.Column="1"
														Content="Alkalmi hozzáférés"
														Style="{StaticResource Button.Secondary}"
														Padding="12,7"
														Visibility="{Binding DataContext.CanManageUserAccess, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
														Command="{Binding DataContext.GrantTemporaryAccessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
														CommandParameter="{Binding}"
														ToolTip="Felhasználó-alapú időkorlátos hozzáférés adása"/>
                                            </Grid>

                                            <!-- Access summary -->
                                            <StackPanel Grid.Row="2">

                                                <TextBlock Text="SZEREPKÖR-ALAPÚ LÁTHATÓSÁG"
                                                           Style="{StaticResource Text.Caption}"
                                                           Margin="0,0,0,8"/>

                                                <Border CornerRadius="6"
                                                        Background="{DynamicResource Brush.Surface.Base}"
                                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                        BorderThickness="1"
                                                        Padding="12,10"
                                                        Margin="0,0,0,12">
                                                    <TextBlock Text="{Binding RoleAccessSummary}"
                                                               Style="{StaticResource Text.BodySmall}"
                                                               FontWeight="SemiBold"/>
                                                </Border>

                                                <TextBlock Text="ALKALMI HOZZÁFÉRÉSEK"
                                                           Style="{StaticResource Text.Caption}"
                                                           Margin="0,0,0,8"/>

                                                <TextBlock Text="Nincs aktív alkalmi hozzáférés"
                                                           Style="{StaticResource Text.Caption}"
                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                           Margin="0,0,0,8"
                                                           Visibility="{Binding HasTemporaryAccessRules, Converter={StaticResource InvBoolToVis}}"/>

                                                <ItemsControl ItemsSource="{Binding TemporaryAccessRules}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="6"
                                                                    Background="{DynamicResource Brush.Surface.Base}"
                                                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                                    BorderThickness="1"
                                                                    Padding="12,10"
                                                                    Margin="0,0,0,8">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="{Binding AdUsername, TargetNullValue=Ismeretlen felhasználó}"
                                                                                   Style="{StaticResource Text.BodySmall}"
                                                                                   FontWeight="SemiBold"/>

                                                                        <TextBlock Text="Felhasználó-alapú alkalmi hozzáférés"
                                                                                   Style="{StaticResource Text.Caption}"
                                                                                   Margin="0,3,0,0"/>
                                                                    </StackPanel>

                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding ExpiresAt, Converter={StaticResource ShortDateConv}, StringFormat=Lejár: {0}}"
                                                                               Style="{StaticResource Text.Caption}"
                                                                               VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Megjegyzés: ez jelenleg read-only összefoglaló nézet. Az alkalmi hozzáférés ablak és a szerepkör-kezelés a következő lépésben kerül bekötésre."
                                   Style="{StaticResource Text.Caption}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>