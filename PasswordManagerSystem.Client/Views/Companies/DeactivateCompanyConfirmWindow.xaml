<Window x:Class="PasswordManagerSystem.Client.Views.Companies.DeactivateCompanyConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ceg elrejtese"
        Width="520"
        Height="285"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0B101A"
        Foreground="#E5E7EB">

    <Border BorderBrush="#1F2937"
            BorderThickness="1"
            Background="#0B101A">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#0B101A"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Ceg elrejtese"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#E5E7EB"/>

                <Button Grid.Column="1"
                        Content="X"
                        Click="CancelButton_OnClick"
                        Background="Transparent"
                        Foreground="#E5E7EB"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>
            </Grid>

            <Border Grid.Row="1"
                    Margin="18"
                    Padding="22"
                    Background="#111827"
                    CornerRadius="12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Biztosan el szeretne rejteni ezt a ceget?"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#F9FAFB"/>

                    <Border Grid.Row="2"
                            Padding="12,10"
                            CornerRadius="6"
                            Background="#1F2937"
                            BorderBrush="#374151"
                            BorderThickness="1">
                        <TextBlock x:Name="CompanyNameText"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#E5E7EB"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Grid.Row="4"
                               Text="A ceg nem torlodik az adatbazisbol, csak inaktiv statuszba kerul. Ezutan a normal listakban es keresesben nem fog megjelenni."
                               FontSize="13"
                               Foreground="#CBD5E1"
                               TextWrapping="Wrap"/>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Content="Megse"
                                Height="36"
                                Click="CancelButton_OnClick"
                                Background="#1F2937"
                                Foreground="#E5E7EB"
                                BorderBrush="#374151"/>

                        <Button Grid.Column="3"
                                Content="Elrejtes"
                                Height="36"
                                Click="ConfirmButton_OnClick"
                                Background="#DC2626"
                                Foreground="#FFFFFF"
                                BorderBrush="#DC2626"
                                FontWeight="SemiBold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>