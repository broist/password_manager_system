<Window x:Class="PasswordManagerSystem.Client.Views.Credentials.CredentialEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uj bejegyzes"
        Width="560"
        Height="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0B101A"
        Foreground="#E5E7EB">

    <Window.Resources>
        <Style x:Key="EditorLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="EditorTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="CaretBrush" Value="#22D3EE"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="EditorPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="CaretBrush" Value="#22D3EE"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="EditorComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="EditorComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource EditorComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#1F2937"
                                                BorderBrush="#374151"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#9CA3AF"
                                                      Width="8"
                                                      Height="4"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="10,0,32,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#111827"
                                        BorderBrush="#374151"
                                        BorderThickness="1">
                                    <ScrollViewer MaxHeight="180">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#1F2937"
            BorderThickness="1"
            Background="#0B101A">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#0B101A"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Uj bejegyzes"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#E5E7EB"/>

                <Button Grid.Column="1"
                        Content="X"
                        Click="CloseButton_OnClick"
                        Background="Transparent"
                        Foreground="#9CA3AF"
                        BorderThickness="0"
                        FontWeight="SemiBold"/>
            </Grid>

            <Border Grid.Row="1"
                    Margin="18"
                    Padding="22"
                    Background="#111827"
                    CornerRadius="12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Uj bejegyzes"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#F9FAFB"/>

                        <TextBlock Text="{Binding CompanyName}"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="9"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="9"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="9"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="9"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="9"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="CIM" Style="{StaticResource EditorLabel}"/>
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="FELHASZNALONEV" Style="{StaticResource EditorLabel}"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4">
                            <TextBlock Text="JELSZO" Style="{StaticResource EditorLabel}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>

                                <PasswordBox x:Name="PasswordInput"
                                             Grid.Column="0"
                                             Style="{StaticResource EditorPasswordBox}"
                                             PasswordChanged="PasswordInput_OnPasswordChanged"/>

                                <Button Grid.Column="2"
                                        Content="Generalas"
                                        Height="36"
                                        Click="GenerateButton_OnClick"
                                        Background="#22D3EE"
                                        Foreground="#07111F"
                                        BorderBrush="#22D3EE"
                                        FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="6">
                            <TextBlock Text="KAPCSOLODAS" Style="{StaticResource EditorLabel}"/>

								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="12"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>

									<TextBox Grid.Column="0"
											 Text="{Binding ConnectionValue, UpdateSourceTrigger=PropertyChanged}"
											 Style="{StaticResource EditorTextBox}"/>

									<Button Grid.Column="2"
											Content="Tallozas"
											MinWidth="110"
											Padding="14,8"
											Click="BrowseConnectionFileButton_OnClick"
											Background="#1F2937"
											Foreground="#E5E7EB"
											BorderBrush="#374151"
											BorderThickness="1"/>
								</Grid>

								<TextBlock Text="LATHATOSAG" Style="{StaticResource EditorLabel}"/>

								<ComboBox ItemsSource="{Binding VisibilityOptions}"
										  SelectedItem="{Binding SelectedVisibilityOption, UpdateSourceTrigger=PropertyChanged}"
										  DisplayMemberPath="Name"
										  Style="{StaticResource EditorComboBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="10">
                            <TextBlock Text="MEGJEGYZES" Style="{StaticResource EditorLabel}"/>

                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBox}"
                                     Height="64"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="3"
                               Text="{Binding ErrorMessage}"
                               Foreground="#F87171"
                               TextWrapping="Wrap"
                               FontSize="12"/>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Content="Megse"
                                Height="36"
                                Command="{Binding CancelCommand}"
                                Background="#1F2937"
                                Foreground="#E5E7EB"
                                BorderBrush="#374151"/>

                        <Button Grid.Column="3"
                                Content="Mentes"
                                Height="36"
                                Command="{Binding SaveCommand}"
                                Background="#22D3EE"
                                Foreground="#07111F"
                                BorderBrush="#22D3EE"
                                FontWeight="SemiBold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>