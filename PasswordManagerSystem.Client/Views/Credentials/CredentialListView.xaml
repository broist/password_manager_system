<UserControl x:Class="PasswordManagerSystem.Client.Views.Credentials.CredentialListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.InputBindings>
        <!-- Ctrl+H: jelszó feltárása -->
        <KeyBinding Modifiers="Control" Key="H" Command="{Binding RevealPasswordCommand}"/>
        <!-- Ctrl+C: jelszó másolása -->
        <KeyBinding Modifiers="Control" Key="C" Command="{Binding CopyPasswordCommand}"/>
        <!-- Ctrl+B: felhasználónév másolása -->
        <KeyBinding Modifiers="Control" Key="B" Command="{Binding CopyUsernameCommand}"/>
        <!-- Ctrl+U: kapcsolódás (URL/RDP) -->
        <KeyBinding Modifiers="Control" Key="U" Command="{Binding OpenConnectionCommand}"/>
    </UserControl.InputBindings>

    <Grid Background="{DynamicResource Brush.Surface.Panel}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="2*" MinWidth="320"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="3*" MinWidth="380"/>
        </Grid.ColumnDefinitions>

        <!-- ========================== COL 1: Companies ========================== -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="20,18,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Cégek"
                           Style="{StaticResource Text.Heading3}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Companies.Count, StringFormat={}{0}}"
                           Style="{StaticResource Text.Caption}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Companies list -->
            <ListBox Grid.Row="1"
                     Margin="8,0,8,12"
                     ItemsSource="{Binding Companies}"
                     SelectedItem="{Binding SelectedCompany, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="6,0">
                            <Path Data="{StaticResource Icon.Building}"
                                  Stroke="{DynamicResource Brush.Text.Tertiary}"
                                  StrokeThickness="1.5"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- divider -->
        <Border Grid.Column="1" Background="{DynamicResource Brush.Border.Subtle}"/>

        <!-- ========================== COL 2: Credentials list ========================== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header with search -->
            <Grid Grid.Row="0" Margin="20,18,20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Bejegyzések"
                               Style="{StaticResource Text.Heading3}"/>
                    <TextBlock Style="{StaticResource Text.Caption}"
                               Margin="0,4,0,0">
                        <Run Text="{Binding Credentials.Count, Mode=OneWay}"/>
                        <Run Text="db"/>
                        <Run Text="•"/>
                        <Run Text="{Binding SelectedCompany.Name, FallbackValue=Minden cég}"/>
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1"
						Style="{StaticResource Button.Primary}"
						VerticalAlignment="Center"
						Padding="14,8"
						Command="{Binding CreateCredentialCommand}"
						ToolTip="Új bejegyzés">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.Plus}"
                              Stroke="{DynamicResource Brush.Text.OnAccent}"
                              StrokeThickness="2"
                              Width="14" Height="14"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="Új"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Text.OnAccent}"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Search box -->
			<Grid Grid.Row="1"
				  Height="40"
				  Margin="20,0,20,16">
				<TextBox x:Name="SearchTextBox"
						 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
						 Background="{DynamicResource Brush.Surface.Card}"
						 BorderBrush="{DynamicResource Brush.Border.Subtle}"
						 BorderThickness="1"
						 Foreground="{DynamicResource Brush.Text.Primary}"
						 CaretBrush="{DynamicResource Brush.Accent.Primary}"
						 FontSize="13"
						 Padding="42,0,12,0"
						 HorizontalAlignment="Stretch"
						 VerticalAlignment="Stretch"
						 HorizontalContentAlignment="Left"
						 VerticalContentAlignment="Center"
						 TextAlignment="Left"/>

				<Path Data="{StaticResource Icon.Search}"
					  Width="15"
					  Height="15"
					  Stretch="Uniform"
					  Stroke="{DynamicResource Brush.Text.Muted}"
					  StrokeThickness="1.7"
					  HorizontalAlignment="Left"
					  VerticalAlignment="Center"
					  Margin="16,0,0,0"
					  IsHitTestVisible="False"/>

				<TextBlock Text="Keresés"
						   Foreground="#CBD5E1"
						   FontSize="13"
						   Margin="42,0,12,0"
						   HorizontalAlignment="Left"
						   VerticalAlignment="Center"
						   IsHitTestVisible="False">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Setter Property="Visibility" Value="Collapsed"/>
							<Style.Triggers>
								<DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
									<Setter Property="Visibility" Value="Visible"/>
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
			</Grid>

            <!-- Credentials -->
            <ListBox Grid.Row="2"
                     Margin="12,0,12,12"
                     ItemsSource="{Binding Credentials}"
                     SelectedItem="{Binding SelectedCredential, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Connection type indicator badge -->
                            <Border Grid.Column="0"
                                    Width="30" Height="30"
                                    CornerRadius="6"
                                    Background="{DynamicResource Brush.Surface.Elevated}"
                                    VerticalAlignment="Center">
                                <Path Width="16" Height="16"
                                      Stroke="{DynamicResource Brush.Text.Tertiary}"
                                      StrokeThickness="1.5"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource Icon.Key}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ConnectionValue, Converter={StaticResource ConnTypeConv}}" Value="URL">
                                                    <Setter Property="Data" Value="{StaticResource Icon.Globe}"/>
                                                    <Setter Property="Stroke" Value="{DynamicResource Brush.Info}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ConnectionValue, Converter={StaticResource ConnTypeConv}}" Value="RDP">
                                                    <Setter Property="Data" Value="{StaticResource Icon.Monitor}"/>
                                                    <Setter Property="Stroke" Value="{DynamicResource Brush.Role.ItAdmin}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           Style="{StaticResource Text.Body}"
                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding CompanyName}"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- Last accessed indikátor -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding LastAccessedAt, Converter={StaticResource ShortDateConv}}"
                                       Style="{StaticResource Text.Caption}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       Visibility="{Binding LastAccessedAt, Converter={StaticResource NotNullToVis}}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- divider -->
        <Border Grid.Column="3" Background="{DynamicResource Brush.Border.Subtle}"/>

        <!-- ========================== COL 3: Detail panel ========================== -->
        <Grid Grid.Column="4" Background="{DynamicResource Brush.Surface.Panel}">

            <!-- Empty state -->
            <StackPanel Visibility="{Binding HasSelectedCredential, Converter={StaticResource InvBoolToVis}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="320">
                <Border Width="56" Height="56"
                        CornerRadius="28"
                        Background="{DynamicResource Brush.Accent.Subtle}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <Path Data="{StaticResource Icon.Key}"
                          Stroke="{DynamicResource Brush.Accent.Default}"
                          StrokeThickness="1.5"
                          Width="24" Height="24"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Nincs kiválasztott bejegyzés"
                           Style="{StaticResource Text.Heading3}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Válassz a bal oldali listából, vagy hozz létre újat."
                           Style="{StaticResource Text.Body}"
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>

            <!-- Selected credential detail -->
            <Grid Visibility="{Binding HasSelectedCredential, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Detail header -->
                <Border Grid.Row="0"
                        Padding="28,18,28,18"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding SelectedCredential.Title}"
                                       Style="{StaticResource Text.Heading2}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding IsEditMode, Converter={StaticResource InvBoolToVis}}"/>

                            <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="{StaticResource Font.Size.XL}"
                                     FontWeight="SemiBold"
                                     Padding="10,8"
                                     Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Path Data="{StaticResource Icon.Building}"
                                      Stroke="{DynamicResource Brush.Text.Tertiary}"
                                      StrokeThickness="1.5"
                                      Width="13" Height="13"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedCredential.CompanyName}"
                                           Style="{StaticResource Text.BodySmall}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource Button.Primary}"
                                VerticalAlignment="Top"
                                Padding="14,8"
                                Command="{Binding StartEditCommand}"
                                Visibility="{Binding IsEditMode, Converter={StaticResource InvBoolToVis}}"
                                ToolTip="Szerkesztés">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon.Edit}"
                                      Stroke="{DynamicResource Brush.Text.OnAccent}"
                                      StrokeThickness="1.7"
                                      Width="14" Height="14"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="EDIT"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Text.OnAccent}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Detail body -->
                <ScrollViewer Grid.Row="1"
                              Padding="28,20,28,20"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <!-- Readonly mode -->
                        <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource InvBoolToVis}}">

                            <!-- Felhasználónév -->
                            <TextBlock Text="FELHASZNÁLÓNÉV"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,0,0,8"/>
                            <Border CornerRadius="6"
                                    Background="{DynamicResource Brush.Surface.Elevated}"
                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    Padding="14,10"
                                    Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="•••••••••••"
                                                   Style="{StaticResource Text.Mono}"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   FontSize="{StaticResource Font.Size.LG}"
                                                   Visibility="{Binding IsUsernameRevealed, Converter={StaticResource InvBoolToVis}}"/>
                                        <TextBox Text="{Binding RevealedUsername, Mode=OneWay}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="0"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 FontSize="{StaticResource Font.Size.LG}"
                                                 IsReadOnly="True"
                                                 Visibility="{Binding IsUsernameRevealed, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource Button.Icon}"
                                                Command="{Binding RevealUsernameCommand}"
                                                ToolTip="Megmutat"
                                                Visibility="{Binding IsUsernameRevealed, Converter={StaticResource InvBoolToVis}}">
                                            <Path Data="{StaticResource Icon.Eye}"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                  StrokeThickness="1.5"
                                                  Width="16" Height="16"
                                                  Stretch="Uniform"/>
                                        </Button>
                                        <Button Style="{StaticResource Button.Icon}"
                                                Command="{Binding ToggleHideUsernameCommand}"
                                                ToolTip="Elrejt"
                                                Visibility="{Binding IsUsernameRevealed, Converter={StaticResource BoolToVis}}">
                                            <Path Data="{StaticResource Icon.EyeOff}"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                  StrokeThickness="1.5"
                                                  Width="16" Height="16"
                                                  Stretch="Uniform"/>
                                        </Button>
                                        <Button Style="{StaticResource Button.Icon}"
                                                Command="{Binding CopyUsernameCommand}"
                                                ToolTip="Másolás (Ctrl+B)">
                                            <Path Data="{StaticResource Icon.Copy}"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                  StrokeThickness="1.5"
                                                  Width="16" Height="16"
                                                  Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Jelszó -->
                            <TextBlock Text="JELSZÓ"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,0,0,8"/>
                            <Border CornerRadius="6"
                                    Background="{DynamicResource Brush.Surface.Elevated}"
                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    Padding="14,10"
                                    Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="•••••••••••••••"
                                                   Style="{StaticResource Text.Mono}"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   FontSize="{StaticResource Font.Size.LG}"
                                                   Visibility="{Binding IsPasswordRevealed, Converter={StaticResource InvBoolToVis}}"/>
                                        <TextBox Text="{Binding RevealedPassword, Mode=OneWay}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="0"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 FontSize="{StaticResource Font.Size.LG}"
                                                 Foreground="{DynamicResource Brush.Accent.Default}"
                                                 IsReadOnly="True"
                                                 Visibility="{Binding IsPasswordRevealed, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource Button.Icon}"
                                                Command="{Binding RevealPasswordCommand}"
                                                ToolTip="Megmutat (Ctrl+H)"
                                                Visibility="{Binding IsPasswordRevealed, Converter={StaticResource InvBoolToVis}}">
                                            <Path Data="{StaticResource Icon.Eye}"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                  StrokeThickness="1.5"
                                                  Width="16" Height="16"
                                                  Stretch="Uniform"/>
                                        </Button>
                                        <Button Style="{StaticResource Button.Icon}"
                                                Command="{Binding ToggleHidePasswordCommand}"
                                                ToolTip="Elrejt"
                                                Visibility="{Binding IsPasswordRevealed, Converter={StaticResource BoolToVis}}">
                                            <Path Data="{StaticResource Icon.EyeOff}"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                  StrokeThickness="1.5"
                                                  Width="16" Height="16"
                                                  Stretch="Uniform"/>
                                        </Button>
                                        <Button Style="{StaticResource Button.Icon}"
                                                Command="{Binding CopyPasswordCommand}"
                                                ToolTip="Másolás (Ctrl+C)">
                                            <Path Data="{StaticResource Icon.Copy}"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                  StrokeThickness="1.5"
                                                  Width="16" Height="16"
                                                  Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Kapcsolódás -->
                            <TextBlock Text="KAPCSOLÓDÁS"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,0,0,8"/>
                            <Border CornerRadius="6"
                                    Background="{DynamicResource Brush.Surface.Elevated}"
                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    Padding="14,10"
                                    Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Padding="6,2"
                                            CornerRadius="3"
                                            Background="{DynamicResource Brush.Surface.Overlay}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedCredential.ConnectionValue, Converter={StaticResource ConnTypeConv}}"
                                                   Style="{StaticResource Text.Caption}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"/>
                                    </Border>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedCredential.ConnectionValue, FallbackValue=—}"
                                               Style="{StaticResource Text.Mono}"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <Button Grid.Column="2"
                                            Style="{StaticResource Button.Icon}"
                                            Command="{Binding OpenConnectionCommand}"
                                            ToolTip="Megnyitás (Ctrl+U)">
                                        <Path Data="{StaticResource Icon.Globe}"
                                              Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                              StrokeThickness="1.5"
                                              Width="16" Height="16"
                                              Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Megjegyzés -->
                            <TextBlock Text="MEGJEGYZÉS"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding SelectedCredential.Notes, Converter={StaticResource StringNotEmptyToVis}}"/>
                            <Border CornerRadius="6"
                                    Background="{DynamicResource Brush.Surface.Elevated}"
                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    Padding="14,10"
                                    Margin="0,0,0,18"
                                    Visibility="{Binding SelectedCredential.Notes, Converter={StaticResource StringNotEmptyToVis}}">
                                <TextBlock Text="{Binding SelectedCredential.Notes}"
                                           Style="{StaticResource Text.Body}"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <!-- Meta info -->
                            <Border Margin="0,12,0,0"
                                    Padding="14,12"
                                    Background="{DynamicResource Brush.Surface.Base}"
                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="LÉTREHOZVA" Style="{StaticResource Text.Caption}"/>
                                        <TextBlock Text="{Binding SelectedCredential.CreatedAt, Converter={StaticResource ShortDateConv}}"
                                                   Style="{StaticResource Text.BodySmall}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="MÓDOSÍTVA" Style="{StaticResource Text.Caption}"/>
                                        <TextBlock Text="{Binding SelectedCredential.UpdatedAt, Converter={StaticResource ShortDateConv}}"
                                                   Style="{StaticResource Text.BodySmall}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,0,0">
                                        <TextBlock Text="UTOLSÓ HOZZÁFÉRÉS" Style="{StaticResource Text.Caption}"/>
                                        <TextBlock Text="{Binding SelectedCredential.LastAccessedAt, Converter={StaticResource ShortDateConv}, TargetNullValue='—', FallbackValue='—'}"
                                                   Style="{StaticResource Text.BodySmall}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Edit mode -->
                        <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="FELHASZNÁLÓNÉV"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditUsername, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{StaticResource Font.Mono}"
                                     Padding="12,9"
                                     Margin="0,0,0,18"/>

                            <TextBlock Text="JELSZÓ"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditPassword, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{StaticResource Font.Mono}"
                                     Foreground="{DynamicResource Brush.Accent.Default}"
                                     Padding="12,9"
                                     Margin="0,0,0,18"/>

                            <TextBlock Text="KAPCSOLÓDÁS"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditConnectionValue, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{StaticResource Font.Mono}"
                                     Padding="12,9"
                                     Margin="0,0,0,18"/>

                            <TextBlock Text="MEGJEGYZÉS"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="100"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="12,9"
                                     Margin="0,0,0,18"/>

                            <Border Padding="12,10"
                                    CornerRadius="6"
                                    Background="{DynamicResource Brush.Surface.Base}"
                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    Visibility="{Binding EditErrorMessage, Converter={StaticResource StringNotEmptyToVis}}">
                                <TextBlock Text="{Binding EditErrorMessage}"
                                           Foreground="{DynamicResource Brush.Danger}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- Footer actions -->
				<Border Grid.Row="2"
						Padding="28,10"
						Background="{DynamicResource Brush.Surface.Sidebar}"
						BorderBrush="{DynamicResource Brush.Border.Subtle}"
						BorderThickness="0,1,0,0">
					<Grid>
						<Grid Visibility="{Binding IsEditMode, Converter={StaticResource InvBoolToVis}}">

							<Button Style="{StaticResource Button.Danger}"
									Command="{Binding DeleteCredentialCommand}"
									Padding="16,9"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									ToolTip="Bejegyzes torlese">
								<StackPanel Orientation="Horizontal">
									<Path Data="{StaticResource Icon.Trash}"
										  Stroke="White"
										  StrokeThickness="1.7"
										  Width="14"
										  Height="14"
										  Stretch="Uniform"
										  VerticalAlignment="Center"/>
									<TextBlock Text="DELETE"
											   Margin="8,0,0,0"
											   VerticalAlignment="Center"
											   Foreground="White"/>
								</StackPanel>
							</Button>

