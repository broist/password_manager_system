<Window x:Class="PasswordManagerSystem.Client.Views.Credentials.DeleteConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Torles megerositese"
        Width="520"
        Height="315"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0B101A"
        Foreground="#E5E7EB">

    <Window.Resources>
        <Style x:Key="CopyIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="Masolas vagolapra"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F2937"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#1F2937"
            BorderThickness="1"
            Background="#0B101A">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#0B101A"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Torles megerositese"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#E5E7EB"/>

                <Button Grid.Column="1"
                        Content="X"
                        Click="CancelButton_OnClick"
                        Background="Transparent"
                        Foreground="#E5E7EB"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>
            </Grid>

            <Border Grid.Row="1"
                    Margin="18"
                    Padding="22"
                    Background="#111827"
                    CornerRadius="12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Amennyiben biztosan torolni szeretne az egesz bejegyzest, irja be:"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="#E5E7EB"/>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="permanently delete"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#F87171"
                                   VerticalAlignment="Center"/>

                        <Button Style="{StaticResource CopyIconButtonStyle}"
                                Margin="10,0,0,0"
                                Click="CopyRequiredTextButton_OnClick">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="20" Height="20">
                                    <Rectangle Width="9"
                                               Height="9"
                                               Canvas.Left="7"
                                               Canvas.Top="4"
                                               Stroke="#9CA3AF"
                                               StrokeThickness="1.8"
                                               RadiusX="1"
                                               RadiusY="1"/>
                                    <Rectangle Width="9"
                                               Height="9"
                                               Canvas.Left="4"
                                               Canvas.Top="7"
                                               Stroke="#9CA3AF"
                                               StrokeThickness="1.8"
                                               RadiusX="1"
                                               RadiusY="1"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <TextBox x:Name="ConfirmInput"
                             Grid.Row="4"
                             Height="42"
                             Padding="10,0"
                             FontSize="14"
                             Background="#1F2937"
                             Foreground="#F9FAFB"
                             CaretBrush="#22D3EE"
                             BorderBrush="#374151"
                             BorderThickness="1"
                             VerticalContentAlignment="Center"/>

                    <TextBlock x:Name="ErrorText"
                               Grid.Row="5"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="#F87171"
                               FontSize="12"/>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Content="Megse"
                                Height="36"
                                Click="CancelButton_OnClick"
                                Background="#1F2937"
                                Foreground="#E5E7EB"
                                BorderBrush="#374151"/>

                        <Button Grid.Column="3"
                                Content="DELETE"
                                Height="36"
                                Click="DeleteButton_OnClick"
                                Background="#DC2626"
                                Foreground="#FFFFFF"
                                BorderBrush="#DC2626"
                                FontWeight="SemiBold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
