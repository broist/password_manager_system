<Window x:Class="PasswordManagerSystem.Client.Views.Credentials.PasswordGeneratorOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jelszo generalas"
        Width="560"
        Height="310"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0B101A"
        Foreground="#E5E7EB">

    <Border BorderBrush="#1F2937"
            BorderThickness="1"
            Background="#0B101A">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#0B101A"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Jelszo generalas"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#E5E7EB"/>

                <Button Grid.Column="1"
                        Content="X"
                        Click="CancelButton_OnClick"
                        Background="Transparent"
                        Foreground="#9CA3AF"
                        BorderThickness="0"
                        FontWeight="SemiBold"/>
            </Grid>

            <Border Grid.Row="1"
                    Margin="18"
                    Padding="22"
                    Background="#111827"
                    CornerRadius="12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Jelszo hossza"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   Foreground="#E5E7EB"/>

                        <TextBox x:Name="LengthInput"
                                 Grid.Column="1"
                                 Text="20"
                                 Height="34"
                                 Padding="10,5"
                                 Background="#1F2937"
                                 Foreground="#F9FAFB"
                                 CaretBrush="#22D3EE"
                                 BorderBrush="#374151"
                                 VerticalContentAlignment="Center"
                                 TextChanged="LengthInput_OnTextChanged"/>

                        <Slider x:Name="LengthSlider"
                                Grid.Column="3"
                                Minimum="8"
                                Maximum="128"
                                Value="20"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="LengthSlider_OnValueChanged"/>
                    </Grid>

                    <UniformGrid Grid.Row="2"
                                 Columns="4"
                                 HorizontalAlignment="Stretch">
                        <CheckBox x:Name="UppercaseCheck"
                                  Content="Nagybetu"
                                  IsChecked="True"
                                  Foreground="#E5E7EB"
                                  FontSize="14"
                                  Margin="0,0,10,0"/>

                        <CheckBox x:Name="LowercaseCheck"
                                  Content="Kisbetu"
                                  IsChecked="True"
                                  Foreground="#E5E7EB"
                                  FontSize="14"
                                  Margin="0,0,10,0"/>

                        <CheckBox x:Name="DigitsCheck"
                                  Content="Szamok"
                                  IsChecked="True"
                                  Foreground="#E5E7EB"
                                  FontSize="14"
                                  Margin="0,0,10,0"/>

                        <CheckBox x:Name="SpecialCheck"
                                  Content="Szimbolumok"
                                  IsChecked="True"
                                  Foreground="#E5E7EB"
                                  FontSize="14"/>
                    </UniformGrid>

                    <TextBlock x:Name="ErrorText"
                               Grid.Row="3"
                               Foreground="#F87171"
                               FontSize="12"/>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Content="Megse"
                                Height="36"
                                Click="CancelButton_OnClick"
                                Background="#1F2937"
                                Foreground="#E5E7EB"
                                BorderBrush="#374151"/>

                        <Button Grid.Column="3"
                                Content="Generalas"
                                Height="36"
                                Click="GenerateButton_OnClick"
                                Background="#22D3EE"
                                Foreground="#07111F"
                                BorderBrush="#22D3EE"
                                FontWeight="SemiBold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>