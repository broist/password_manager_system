<Window x:Class="PasswordManagerSystem.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:b="clr-namespace:PasswordManagerSystem.Client.Behaviors"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Password Manager System – Bejelentkezés"
        Width="980"
        Height="620"
        MinWidth="780"
        MinHeight="540"
        Style="{StaticResource Window.Modern}"
        WindowStartupLocation="CenterScreen">

    <Border BorderBrush="{DynamicResource Brush.Border.Subtle}"
            BorderThickness="1"
            Background="{DynamicResource Brush.Surface.Base}">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Bal oldali brand panel -->
                <ColumnDefinition Width="430"/>
                <!-- Jobb oldali form -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Window control buttons (zárás), a jobb felső sarokban kell lenniük -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Panel.ZIndex="100"
                        Margin="0,0,0,0"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource Button.Icon}"
                        Width="44" Height="36"
                        Command="{Binding ExitCommand}"
                        ToolTip="Bezárás">
                    <Path Data="{StaticResource Icon.Close}"
                          Stroke="{DynamicResource Brush.Text.Secondary}"
                          StrokeThickness="1.5"
                          Width="14" Height="14"
                          Stretch="Uniform"/>
                </Button>
            </StackPanel>

            <!-- ============== BAL OLDAL: Brand panel ============== -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Login.Background}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="0"
                                      Opacity="0.3"
                                      Color="Black"/>
                </Border.Effect>
                <Grid>
                    <!-- Halvány grid pattern háttér díszítésnek -->
                    <Rectangle Fill="{DynamicResource Brush.Surface.Sidebar}" Opacity="0.4"/>

                    <!-- Decoratív cyan accent kör -->
                    <Ellipse Width="320" Height="320"
                             Fill="{DynamicResource Brush.Accent.Default}"
                             Opacity="0.05"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,-100,-100,0"/>

                    <Ellipse Width="240" Height="240"
                             Fill="{DynamicResource Brush.Accent.Default}"
                             Opacity="0.04"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom"
                             Margin="-80,0,0,-80"/>

                    <!-- Tartalom -->
                    <StackPanel Margin="56,80,56,56"
                                VerticalAlignment="Top">

                        <!-- Logo + Brand név -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,42">
                            <Border Background="{DynamicResource Brush.Accent.Subtle}"
                                    Width="44" Height="44"
                                    CornerRadius="10">
                                <Path Data="{StaticResource Icon.Shield}"
                                      Fill="{DynamicResource Brush.Accent.Default}"
                                      Stroke="{DynamicResource Brush.Accent.Default}"
                                      StrokeThickness="1.5"
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Password Manager"
                                           Style="{StaticResource Text.Heading3}"/>
                                <TextBlock Text="PAM Lite"
                                           Style="{StaticResource Text.Caption}"
                                           Foreground="{DynamicResource Brush.Accent.Default}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Headline -->
                        <TextBlock Style="{StaticResource Text.Heading1}"
                                   Margin="0,0,0,16"
                                   TextWrapping="Wrap"
                                   LineHeight="38">
                            <Run Text="Biztonságos"/>
                            <LineBreak/>
                            <Run Text="hozzáférés-"/>
                            <LineBreak/>
                            <Run Text="kezelés"
                                 Foreground="{DynamicResource Brush.Accent.Default}"/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource Text.BodyLarge}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   TextWrapping="Wrap"
                                   LineHeight="24">
                            Központi credential tárolás Active Directory
                            integrációval, AES-256-GCM titkosítással és
                            hash-chain audit naplóval.
                        </TextBlock>

                        <!-- Feature list -->
                        <StackPanel Margin="0,42,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Path Data="{StaticResource Icon.Check}"
                                      Stroke="{DynamicResource Brush.Accent.Default}"
                                      StrokeThickness="2"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="AD csoport-alapú jogosultság"
                                           Style="{StaticResource Text.Body}"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           Margin="14,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Path Data="{StaticResource Icon.Check}"
                                      Stroke="{DynamicResource Brush.Accent.Default}"
                                      StrokeThickness="2"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="Auditálható jelszó-megtekintés"
                                           Style="{StaticResource Text.Body}"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           Margin="14,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon.Check}"
                                      Stroke="{DynamicResource Brush.Accent.Default}"
                                      StrokeThickness="2"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="KeePass-szerű felület"
                                           Style="{StaticResource Text.Body}"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           Margin="14,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Verzió információ -->
                    <TextBlock Text="v0.1.0 — Szakdolgozati projekt"
                               Style="{StaticResource Text.Caption}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               Margin="56,0,0,28"/>
                </Grid>
            </Border>

            <!-- ============== JOBB OLDAL: Login form ============== -->
            <Grid Grid.Column="1" Background="{DynamicResource Brush.Surface.Base}">

                <StackPanel MaxWidth="380"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="40">

                    <TextBlock Text="Üdvözlünk!"
                               Style="{StaticResource Text.Heading2}"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Jelentkezz be az Active Directory fiókoddal."
                               Style="{StaticResource Text.Body}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               Margin="0,0,0,32"
                               TextWrapping="Wrap"/>

                    <!-- Felhasználónév -->
                    <TextBlock Text="FELHASZNÁLÓNÉV"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="UsernameTextBox"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                             FontSize="{StaticResource Font.Size.MD}"
                             Margin="0,0,0,18"/>

                    <!-- Jelszó -->
                    <TextBlock Text="JELSZÓ"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="PasswordBox"
                               IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                               FontSize="{StaticResource Font.Size.MD}"
                               Margin="0,0,0,18"
                               KeyDown="PasswordBox_KeyDown"/>

                    <!-- Hibaüzenet -->
                    <Border Background="{DynamicResource Brush.Danger.Subtle}"
                            BorderBrush="{DynamicResource Brush.Danger}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,10"
                            Margin="0,0,0,18"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource Brush.Danger}"
                                   FontSize="{StaticResource Font.Size.SM}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Login gomb -->
                    <Button Style="{StaticResource Button.Primary}"
                            Content="Bejelentkezés"
                            Command="{Binding LoginCommand}"
                            IsDefault="True"
                            Height="42"
                            FontSize="{StaticResource Font.Size.MD}"
                            Margin="0,8,0,0"/>

                    <!-- Loading indicator -->
                    <ProgressBar IsIndeterminate="True"
                                 Height="2"
                                 Margin="0,16,0,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource Brush.Accent.Default}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

                    <!-- Dev info hint -->
                    <Border Background="{DynamicResource Brush.Surface.Elevated}"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,12"
                            Margin="0,32,0,0">
                        <StackPanel>
                            <TextBlock Text="FEJLESZTŐI TIPP"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap"
                                       FontSize="{StaticResource Font.Size.SM}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}">
                                <Run Text="Mock AD: a felhasználónév tartalmazza valamelyiket"/>
                                <LineBreak/>
                                <Run Text="(admin / it / consultant / support), jelszó:"/>
                                <Run Text="Test1234!"
                                     Foreground="{DynamicResource Brush.Accent.Default}"
                                     FontFamily="{StaticResource Font.Mono}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
