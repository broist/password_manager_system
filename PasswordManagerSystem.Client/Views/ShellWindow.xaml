<Window x:Class="PasswordManagerSystem.Client.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:PasswordManagerSystem.Client.ViewModels"
        xmlns:credvm="clr-namespace:PasswordManagerSystem.Client.ViewModels.Credentials"
        xmlns:credv="clr-namespace:PasswordManagerSystem.Client.Views.Credentials"
        xmlns:compvm="clr-namespace:PasswordManagerSystem.Client.ViewModels.Companies"
        xmlns:compv="clr-namespace:PasswordManagerSystem.Client.Views.Companies"
        xmlns:accessvm="clr-namespace:PasswordManagerSystem.Client.ViewModels.Access"
        xmlns:accessv="clr-namespace:PasswordManagerSystem.Client.Views.Access"
        xmlns:auditvm="clr-namespace:PasswordManagerSystem.Client.ViewModels.Audit"
        xmlns:auditv="clr-namespace:PasswordManagerSystem.Client.Views.Audit"
        mc:Ignorable="d"
        Title="Password Manager System"
        Width="1320"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        Style="{StaticResource Window.Modern}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- DataTemplate-ek a tartalom-host ContentControl-hoz: ViewModel típus alapján
             betöltődik a megfelelő nézet. -->
        <DataTemplate DataType="{x:Type credvm:CredentialListViewModel}">
            <credv:CredentialListView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type accessvm:AccessViewModel}">
            <accessv:AccessView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type compvm:CompaniesViewModel}">
            <compv:CompaniesView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type auditvm:AuditViewModel}">
            <auditv:AuditView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
            <Grid Background="{DynamicResource Brush.Surface.Panel}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                    <Border Width="64" Height="64"
                            CornerRadius="32"
                            Background="{DynamicResource Brush.Accent.Subtle}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <Path Data="{StaticResource Icon.Settings}"
                              Stroke="{DynamicResource Brush.Accent.Default}"
                              StrokeThickness="1.5"
                              Width="28" Height="28"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="{Binding FeatureName}"
                               Style="{StaticResource Text.Heading2}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Ez a funkció a következő iterációban érkezik. A backend már támogatja, csak a kliens-oldali UI van hátra."
                               Style="{StaticResource Text.Body}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource Brush.Border.Subtle}"
            BorderThickness="1"
            Background="{DynamicResource Brush.Surface.Base}">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Custom titlebar -->
                <RowDefinition Height="44"/>
                <!-- Tartalom (sidebar + content) -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ============== TITLEBAR ============== -->
            <Grid Grid.Row="0"
                  Background="{DynamicResource Brush.Surface.Sidebar}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App név bal oldalon -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                    <Border Width="22" Height="22"
                            CornerRadius="5"
                            Background="{DynamicResource Brush.Accent.Subtle}">
                        <Path Data="{StaticResource Icon.Shield}"
                              Stroke="{DynamicResource Brush.Accent.Default}"
                              StrokeThickness="1.5"
                              Width="13"
                              Height="13"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Password Manager"
                               Style="{StaticResource Text.BodySmall}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontWeight="SemiBold"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window control buttons -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource Button.Icon}"
                            Width="44"
                            Height="44"
                            Command="{Binding MinimizeCommand}"
                            ToolTip="Minimalizálás">
                        <Path Data="{StaticResource Icon.Minimize}"
                              Stroke="{DynamicResource Brush.Text.Secondary}"
                              StrokeThickness="1.5"
                              Width="14"
                              Height="14"
                              Stretch="Uniform"/>
                    </Button>

                    <Button Style="{StaticResource Button.Icon}"
                            Width="44"
                            Height="44"
                            Command="{Binding ToggleMaximizeCommand}"
                            ToolTip="Méretváltás">
                        <Path Data="{StaticResource Icon.Maximize}"
                              Stroke="{DynamicResource Brush.Text.Secondary}"
                              StrokeThickness="1.5"
                              Width="11"
                              Height="11"
                              Stretch="Uniform"/>
                    </Button>

                    <Button Style="{StaticResource Button.Icon}"
                            Width="44"
                            Height="44"
                            Command="{Binding CloseCommand}"
                            ToolTip="Bezárás">
                        <Path Data="{StaticResource Icon.Close}"
                              Stroke="{DynamicResource Brush.Text.Secondary}"
                              StrokeThickness="1.5"
                              Width="14"
                              Height="14"
                              Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============== TARTALOM ============== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Sidebar -->
                    <ColumnDefinition Width="240"/>
                    <!-- Content -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ============ SIDEBAR ============ -->
                <Border Grid.Column="0"
                        Background="{DynamicResource Brush.Surface.Sidebar}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- User info card a sidebar tetején -->
                        <Border Grid.Row="0"
                                Margin="14,16,14,12"
                                Padding="12"
                                CornerRadius="8"
                                Background="{DynamicResource Brush.Surface.Elevated}"
                                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <!-- Avatar (initials fallback) -->
                                    <Border Width="32"
                                            Height="32"
                                            CornerRadius="16"
                                            Background="{DynamicResource Brush.Accent.Subtle}">
                                        <TextBlock Text="{Binding UserDisplayName, Converter={StaticResource InitialsConv}}"
                                                   Foreground="{DynamicResource Brush.Accent.Default}"
                                                   FontSize="{StaticResource Font.Size.SM}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding UserDisplayName}"
                                                   Style="{StaticResource Text.BodySmall}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Text="{Binding AdUsername}"
                                                   Style="{StaticResource Text.Caption}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Role badge -->
                                <Border Margin="0,10,0,0"
                                        Padding="8,3"
                                        HorizontalAlignment="Left"
                                        CornerRadius="3"
                                        Background="{DynamicResource Brush.Surface.Overlay}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6"
                                                 Height="6"
                                                 Fill="{DynamicResource Brush.Accent.Default}"
                                                 VerticalAlignment="Center"/>

                                        <TextBlock Text="{Binding RoleDisplayName}"
                                                   Style="{StaticResource Text.Caption}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Nav menu -->
                        <ListBox Grid.Row="1"
                                 Margin="8,4"
                                 ItemsSource="{Binding NavigationItems}"
                                 SelectedItem="{Binding SelectedNavItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NavItem}">
                                    <StackPanel Orientation="Horizontal"
                                                Margin="6,0">
                                        <ContentControl Width="18"
                                                        Height="18"
                                                        VerticalAlignment="Center">
                                            <ContentControl.Style>
                                                <Style TargetType="ContentControl">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IconKey}" Value="Icon.Key">
                                                            <Setter Property="Content">
                                                                <Setter.Value>
                                                                    <Path Data="{StaticResource Icon.Key}"
                                                                          Stroke="{DynamicResource Brush.Text.Secondary}"
                                                                          StrokeThickness="1.5"
                                                                          Stretch="Uniform"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding IconKey}" Value="Icon.Building">
                                                            <Setter Property="Content">
                                                                <Setter.Value>
                                                                    <Path Data="{StaticResource Icon.Building}"
                                                                          Stroke="{DynamicResource Brush.Text.Secondary}"
                                                                          StrokeThickness="1.5"
                                                                          Stretch="Uniform"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding IconKey}" Value="Icon.Shield">
                                                            <Setter Property="Content">
                                                                <Setter.Value>
                                                                    <Path Data="{StaticResource Icon.Shield}"
                                                                          Stroke="{DynamicResource Brush.Text.Secondary}"
                                                                          StrokeThickness="1.5"
                                                                          Stretch="Uniform"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding IconKey}" Value="Icon.Activity">
                                                            <Setter Property="Content">
                                                                <Setter.Value>
                                                                    <Path Data="{StaticResource Icon.Activity}"
                                                                          Stroke="{DynamicResource Brush.Text.Secondary}"
                                                                          StrokeThickness="1.5"
                                                                          Stretch="Uniform"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding IconKey}" Value="Icon.Settings">
                                                            <Setter Property="Content">
                                                                <Setter.Value>
                                                                    <Path Data="{StaticResource Icon.Settings}"
                                                                          Stroke="{DynamicResource Brush.Text.Secondary}"
                                                                          StrokeThickness="1.5"
                                                                          Stretch="Uniform"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ContentControl.Style>
                                        </ContentControl>

                                        <TextBlock Text="{Binding Title}"
                                                   Margin="14,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Logout gomb a sidebar alján -->
                        <Border Grid.Row="2"
                                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                BorderThickness="0,1,0,0"
                                Padding="14,12">
                            <Button Style="{StaticResource Button.Ghost}"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding LogoutCommand}"
                                    Padding="10,8">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Icon.LogOut}"
                                          Stroke="{DynamicResource Brush.Text.Secondary}"
                                          StrokeThickness="1.5"
                                          Width="16"
                                          Height="16"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"/>

                                    <TextBlock Text="Kijelentkezés"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>
                </Border>

                <!-- ============ CONTENT AREA ============ -->
                <Grid Grid.Column="1"
                      Background="{DynamicResource Brush.Surface.Panel}">
                    <ContentControl Content="{Binding CurrentView}"/>

                    <!-- Toast notification overlay -->
                    <Border VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,28"
                            MaxWidth="420"
                            CornerRadius="8"
                            Padding="16,12"
                            Visibility="{Binding Toasts.Current.IsVisible, Converter={StaticResource BoolToVis}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource Brush.Surface.Tooltip}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Toasts.Current.Severity}" Value="Success">
                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Success}"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Toasts.Current.Severity}" Value="Warning">
                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Warning}"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Toasts.Current.Severity}" Value="Error">
                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Danger}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20"
                                              ShadowDepth="4"
                                              Opacity="0.5"
                                              Color="Black"/>
                        </Border.Effect>

                        <TextBlock Text="{Binding Toasts.Current.Message}"
                                   Style="{StaticResource Text.Body}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>